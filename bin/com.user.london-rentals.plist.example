<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Launchd job: run the rentals scraper daily at 07:15 local time.

  Setup:
    1. Replace YOUR-USERNAME and YOUR-REPO-PATH below.
    2. Copy this file (without .example) to ~/Library/LaunchAgents/com.user.london-rentals.plist
    3. launchctl load ~/Library/LaunchAgents/com.user.london-rentals.plist
    4. To run immediately: launchctl start com.user.london-rentals
    5. To unload: launchctl unload ~/Library/LaunchAgents/com.user.london-rentals.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.london-rentals</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/YOUR-USERNAME/YOUR-REPO-PATH/bin/run-daily.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/YOUR-USERNAME/YOUR-REPO-PATH</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>15</integer>
  </dict>

  <!-- If the laptop is asleep at 07:15, run as soon as it wakes. -->
  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/YOUR-USERNAME/YOUR-REPO-PATH/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOUR-USERNAME/YOUR-REPO-PATH/logs/launchd.err.log</string>
</dict>
</plist>
